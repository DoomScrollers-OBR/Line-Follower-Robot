[Unit]
Description=Controlador do Seguidor de Linha (start automatico + botao)
After=multi-user.target network.target

[Service]
Type=simple
User=serafim
WorkingDirectory=/home/serafim/Documentos/Line-Follower-Robot
ExecStart=/bin/bash /home/serafim/Documentos/Line-Follower-Robot/iniciar_seguidor.sh
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target
